@import '../../styl/component-include.styl'

.b-excerpts-multiple-generate

  &.ph-block
    
    &.ph-block--animated
      
      .ph-content
        position static
        width auto
        opacity 1
        
      .ph
        position absolute
        top 0
        left 0
        width 100%
        opacity 0
        z-index -1
    
.b-poll

  &__form-bottom-panel
    border 1px solid #f5f5f5
    border-radius 10px
    padding 20px 40px 20px 20px
    display flex
    justify-content space-between
    align-items center
    min-height 110px
    position sticky
    bottom 0
    background #fff
    z-index 100

    &__left
      display flex
      justify-content flex-start
      align-items center
      width calc( 100% - 100px )
      margin-right 15px

    &__num
      font-size $18px
      font-weight $bold
      margin-right 20px

    &__select
        min-width 200px
        max-width 300px
        width calc(100% - 150px)

        label
            transform( translateY(-1.2rem))

    .vs__dropdown-menu
        top auto
        bottom calc( 100% + 1px )

    &.i-bottom .vs__dropdown-menu
        top calc( 100% - 1px )
        bottom auto

    @media( max-width 767px )
        display block
        padding 20px

        &__left
            width auto
            justify-content space-between
            margin-bottom 20px

        &__select
            width auto

        button
            width 100%

  &__form-control
    border 1px solid #f5f5f5
    border-radius 10px
    padding 20px 40px 20px 20px
    display flex
    justify-content space-between
    align-items center
    cursor pointer
    transition-fn( all .3s ease )
    min-height 110px

    @media( max-width 767px )
      padding-right 20px

    &.i-active
      border-color #74C37A

    &.i-disabled
      opacity .2
      pointer-events none
      cursor default

    &__content
      display flex
      justify-content space-between
      align-items center
      margin-right 40px

      @media( max-width 767px )
        display block
        margin-right 20px

    &__img
      width 80px
      height 80px
      border-radius 10px
      margin-right 20px
      background-repeat no-repeat
      background-position center
      background-size cover
      flex-shrink 0

      @media( max-width 767px )
        display block
        width 50%
        height auto
        padding-top 50%
        margin-bottom 15px
        margin-right 0

    &__text
      width 100%

      b
        display block
        font-size $18px
        margin-bottom 5px
        line-height 1.2

      span
        display block
        font-size $14px


  &__checkbox
    position relative
    width 32px
    height 32px
    flex-shrink 0

    [type="checkbox"]:not(:checked),
    [type="checkbox"]:checked
      position absolute
      opacity 0
      pointer-events none

    [type="checkbox"]+span
      position relative
      padding-left 25px
      cursor pointer
      display block
      height 25px
      -webkit-user-select none
      -moz-user-select none
      -ms-user-select none
      user-select none

    [type="checkbox"].filled-in+span:before,
    [type="checkbox"].filled-in+span:after
      content: ''
      left: 0
      position: absolute
      transition-fn( all .25s )
      z-index 1

    [type="checkbox"].filled-in:not(:checked)+span:before
      width 0
      height 0
      left 10px
      top 14px

    [type="checkbox"].filled-in:not(:checked)+span:after
      height 32px
      width 32px
      background-color #f5f5f5
      border-radius 5px
      top 0px
      z-index 0

    [type="checkbox"].filled-in:checked+span:before
      top: 7px
      left: 6px
      width: 20px
      height: 15px
      background embedurl('img/checkbox.svg') no-repeat center
      background-size cover

    [type="checkbox"].filled-in:checked+span:after
      top 0
      width 32px
      height 32px
      background-color #74C37A
      border-radius 5px
      z-index 0

.b-loading-status
    display flex
    justify-content space-between
    align-items center
    min-height 80px
    padding 20px
    border-bottom 1px solid $placeholder-color

    b
        line-height 1.2
        margin-right 15px

.b-generated
    display flex
    justify-content space-between
    align-items center
    min-height 80px
    padding 20px
    border-bottom 1px solid $placeholder-color
    margin-bottom 40px

    &__left

        a
            font-weight bold
            margin-right 30px

        span
            white-space nowrap

    &__right
      display flex
      justify-content flex-end
      align-items center

      > a
        background-repeat no-repeat
        background-position right center
        background-size 36px
        display inline-block
        padding-right 50px
        min-height 36px
        line-height 36px
        white-space nowrap

@import './style/select.styl'

/*Bottom animation*/
.slide-fade-enter-active,
.slide-fade-leave-active
    transition-fn( all 0.8s ease)

.slide-fade-enter-from,
.slide-fade-leave-to
    transform( translateY(20px))
    opacity 0

.b-excerpts

  &__more
    position relative

    &__button
      display block
      width 32px
      height 32px
      border-radius 5px
      position relative
      background-color #F0F5FC
      background-repeat no-repeat
      background-position center
      background-size cover
      margin-left 35px

    &__files
      position absolute
      top calc( -54px / 2 - -32px / 2)
      right 42px
      box-shadow 0px 3px 6px #0000001A
      background-color #fff
      padding 11px 11px 11px 23px
      border-radius 7px
      display flex
      justify-content space-between
      align-items center
      opacity 0
      transition-fn(opacity .3s ease)
      z-index -1

      &.show
        opacity 1
        z-index 1

      span
        font-size $12px
        white-space nowrap
        margin-right 14px

      a
        display inline-block
        white-space nowrap
        padding-left 34px
        background-repeat no-repeat
        background-position left center
        background-size contain
        line-height 32px
        margin-left 16px
        font-size $9px

.twpx-doc {
  font-family: Roboto,sans-serif;
  padding: 16px;
  background-color: #fafbfc;
  --aas-docs-block-icon-width: 24px;
  --aas-docs-block-icon-height: 32px;
  --aas-docs-block-gap: 16px;
  --aas-docs-block-button-width: 0
}

.twpx-doc--button {
  flex-shrink: 0;
  --aas-docs-block-icon-margin: 16px;
  --aas-docs-block-button-width: 38px
}

.twpx-doc__body {
  display: flex;
  align-items: center;
  gap: var(--aas-docs-block-gap);
}

.twpx-doc__icon {
  width: var(--aas-docs-block-icon-width);
  height: var(--aas-docs-block-icon-height);
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
  flex-shrink: 0;
  align-self: flex-start;
}

.twpx-doc__text {
  display: grid;
  gap: 8px;
  width: 100%;
}

.twpx-doc__name {
  font-size: 16px;
  font-weight: 700;
  line-height: normal;
  display: inline-block;
  word-break: break-word
}

.twpx-doc__data {
  display: flex;
  column-gap: 16px;
  row-gap: 4px;
  flex-wrap: wrap;
}

.twpx-doc__data span {
  white-space: nowrap;
  font-size: 12px;
  line-height: normal;
  color: var(--grey-muted-text, #6A6A6A);
}

.twpx-doc .btn,.twpx-doc .btn:hover,.twpx-doc .btn:focus,.twpx-doc .btn:active {
  color: #9b9b9b !important
}

.twpx-doc .btn.active,.twpx-doc .btn.active:hover,.twpx-doc .btn.active:focus,.twpx-doc .btn.active:active {
  color: #f39442 !important
}

.twpx-doc.twpx-doc--small {
  padding: 0;
  border: none;
  font-size: .69rem
}

.twpx-doc.twpx-doc--small .twpx-doc__icon {
  width: 30px;
  height: 40px;
  margin-right: 20px;
  margin-bottom: 0;
  flex-shrink: 0
}

.twpx-doc.twpx-doc--small .twpx-doc__data span {
  font-size: .69rem
}

.twpx-doc__collapsed {
  margin-top: 15px;
  margin-left: 105px;
  display: none
}

.twpx-doc__collapsed .twpx-doc {
  display: flex;
  align-items: center;
  margin-bottom: 25px;
  opacity: 0;
  transform: translateX(50px);
  -webkit-transform: translateX(50px);
  transition: all .5s ease .7s;
  -webkit-transition: all .5s ease .7s
}

.twpx-doc__collapsed .twpx-doc:nth-child(1) {
  transition-delay: .3s
}

.twpx-doc__collapsed .twpx-doc:nth-child(2) {
  transition-delay: .4s
}

.twpx-doc__collapsed .twpx-doc:nth-child(3) {
  transition-delay: .5s
}

.twpx-doc__collapsed .twpx-doc:nth-child(4) {
  transition-delay: .6s
}

.twpx-doc__collapsed .twpx-doc__icon {
  width: 24px;
  height: 33px;
  margin-right: 10px;
  margin-bottom: 5px
}

.twpx-doc__collapsed .twpx-doc__text {
  width: calc(100% - 24px - 20px);
  font-size: .69rem
}

.twpx-doc__collapsed .twpx-doc__text a {
  margin-bottom: 3px
}

.twpx-doc__collapsed .twpx-doc__data {
  display: block
}

.twpx-doc__collapsed .twpx-doc__data span {
  font-size: .625rem;
  line-height: 24px
}

.twpx-doc__collapsed.active .twpx-doc {
  opacity: 1;
  transform: translateX(0);
  -webkit-transform: translateX(0)
}

.twpx-doc--gray {
  background-color: #fafafa;
  padding: 20px 16px !important;
  border-radius: 8px
}

.twpx-doc--with-dots .twpx-doc__icon {
  margin-right: 10px !important
}

.twpx-doc--with-dots .twpx-doc__text a {
  font-size: 1rem;
  font-weight: 700
}

.twpx-doc--with-dots .twpx-doc__data span {
  font-size: .75rem;
  line-height: normal
}

.twpx-doc__more {
  position: relative
}

.twpx-doc__more__button {
  display: block;
  width: 32px;
  height: 32px;
  border-radius: 5px;
  position: relative;
  background-color: #f0f5fc;
  background-repeat: no-repeat;
  background-position: center;
  background-size: cover;
  margin-left: 35px
}

.twpx-doc__more__files {
  position: absolute;
  top: calc(-54px / 2 - -32px / 2);
  right: 42px;
  box-shadow: 0 3px 6px rgba(0,0,0,0.102);
  background-color: #fff;
  padding: 11px 11px 11px 23px;
  border-radius: 7px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  opacity: 0;
  transition: opacity .3s ease;
  -webkit-transition: opacity .3s ease;
  z-index: -1
}

.twpx-doc__more__files--show {
  opacity: 1;
  z-index: 1
}

.twpx-doc__more__files span {
  font-size: .75rem;
  white-space: nowrap;
  margin-right: 14px
}

.twpx-doc__more__files a {
  display: inline-block;
  white-space: nowrap;
  padding-left: 34px;
  background-repeat: no-repeat;
  background-position: left center;
  background-size: contain;
  line-height: 32px;
  margin-left: 16px;
  font-size: .56rem
}


@container (width < 768px) {
  .twpx-doc .btn {
      display:inline-block;
      margin-top: 7px
  }
  .twpx-doc__collapsed {
      margin-left:55px
  }
  .twpx-doc__collapsed .twpx-doc {
      align-items:flex-start
  }
  .twpx-doc__data {
      display: grid;
  }
}
